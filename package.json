{
  "name": "historic-fuel-stations-fetcher",
  "version": "1.1.0",
  "description": "Fetches historic values from the Spanish government fuel stations API",
  "main": "index.js",
  "scripts": {
    "fetcher:dev": "ts-node -r tsconfig-paths/register src/fetcher/index.ts",
    "fetcher:start": "node dist/fetcher/index.js",
    "fetcher:bundle": "esbuild ./dist/fetcher/index.js --bundle --platform=node --outfile=output/historic_fuel_stations_fetcher.js",
    "importer:dev": "ts-node -r tsconfig-paths/register src/importer/index.ts",
    "importer:start": "node dist/importer/index.js",
    "importer:bundle": "esbuild ./dist/importer/index.js --bundle --platform=node --outfile=output/historic_fuel_stations_importer.js",
    "build": "tsc && tsc-alias",
    "prepare": "ts-patch install"
  },
  "author": "JGeek00",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "esbuild": "0.28.0",
    "luxon": "3.7.2",
    "pg": "8.20.0",
    "pg-copy-streams": "^6.0.5",
    "ts-node": "10.9.2",
    "typia": "12.1.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/dotenv": "8.2.3",
    "@types/luxon": "3.7.1",
    "@types/node": "25.8.0",
    "@types/pg": "8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/uuid": "11.0.0",
    "ts-patch": "3.3.0",
    "tsc-alias": "1.8.17",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}